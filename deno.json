{
  "tasks": {
    "publish": {
      "command": "cargo publish --allow-dirty",
      "dependencies": ["js"]
    },
    "example": {
      "command": "cargo run -- serve example",
      "dependencies": ["js"]
    },
    "js": "deno bundle --platform browser --minify -o dist/cool-stylesheet.js cool-stylesheet.js"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2023"]
  },
  "imports": {
    "@handcraft/lib": "jsr:@handcraft/lib@^3.0.0"
  }
}
